---
import { social } from '@/data/business';

const currentYear = new Date().getFullYear();
---

<footer class="bg-primary-900 text-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <div>
        <h3 class="font-heading font-bold text-xl text-white mb-4">Plume de Lapin</h3>
        <p class="text-white/80 text-sm leading-relaxed">
          Ferme familiale à Lantefontaine. Œufs fermiers, volailles de chair et lapin élevés en plein air.
        </p>
        <a href={social.facebook} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 mt-5 text-sm text-white/80 hover:text-accent-400 transition-colors" aria-label="Suivez-nous sur Facebook">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          Facebook
        </a>
      </div>

      <div>
        <h3 class="font-heading font-bold text-lg text-white mb-4">Contact</h3>
        <address class="not-italic text-sm text-white/80 space-y-2">
          <p>6 rue du château</p>
          <p>54150 Lantefontaine</p>
          <p class="mt-3"><a href="tel:+336XXXXXXXX" class="hover:text-accent-400 transition-colors">06 XX XX XX XX</a></p>
          <p><a href="mailto:contact@plumedelapin.fr" class="hover:text-accent-400 transition-colors">contact@plumedelapin.fr</a></p>
        </address>
      </div>

      <div>
        <h3 class="font-heading font-bold text-lg text-white mb-4">Horaires</h3>
        <div class="text-sm text-white/80 space-y-2">
          <p><strong class="text-white">Vendredi</strong> : 16h – 19h</p>
          <p><strong class="text-white">Samedi</strong> : 9h – 12h</p>
          <p class="mt-3 text-white/60">Sur commande le reste de la semaine</p>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-primary-700 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-white/70">
      <p>&copy; {currentYear} Plume de Lapin — Ferme familiale à Lantefontaine (54)</p>
      <div class="flex gap-4">
        <a href="/mentions-legales" class="hover:text-white transition-colors">Mentions légales</a>
        <a href="/politique-confidentialite" class="hover:text-white transition-colors">Confidentialité</a>
      </div>
    </div>
    <p class="text-center text-[11px] text-white/50 mt-4">
      Site créé par <a href="https://marcm.fr" target="_blank" rel="noopener noreferrer" class="hover:text-white/70 transition-colors">Marc M.</a>
    </p>
  </div>
</footer>
