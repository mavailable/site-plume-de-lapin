---
import CartIcon from '@/components/boutique/CartIcon';

const navLinks = [
  { label: 'Boutique', href: '/boutique' },
  { label: 'Notre histoire', href: '/a-propos' },
  { label: 'Contact', href: '/contact' },
];
---

<header class="sticky top-0 z-40 bg-white/90 backdrop-blur-md shadow-sm">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16" aria-label="Navigation principale">
    <a href="/" class="flex items-center gap-2.5 font-heading font-bold text-primary-800 text-lg">
      <span class="w-9 h-9 bg-primary-100 rounded-full flex items-center justify-center text-primary-600 text-xs font-bold">PL</span>
      Plume de Lapin
    </a>

    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="text-neutral-600 hover:text-primary-600 transition-colors text-sm font-medium">
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-3">
      <CartIcon client:load />
      <a href="/boutique" class="hidden md:inline-flex bg-primary-600 text-white font-semibold text-sm py-2.5 px-6 rounded-full hover:bg-primary-700 shadow-md hover:shadow-lg transition-all min-h-[44px] items-center">
        Commander
      </a>
      <button id="menu-toggle" class="md:hidden p-2 text-neutral-600 hover:text-primary-600 min-w-[44px] min-h-[44px] flex items-center justify-center" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="mobile-menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="md:hidden hidden bg-white border-t border-neutral-100 shadow-lg" role="dialog" aria-label="Menu de navigation">
    <ul class="px-4 py-4 space-y-1">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="block py-3 px-4 text-neutral-600 hover:text-primary-600 hover:bg-primary-50 rounded-xl transition-colors font-medium">
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a href="/boutique" class="block text-center bg-primary-600 text-white font-semibold py-3 px-4 rounded-full hover:bg-primary-700 shadow-md transition-all">
          Commander
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const icon = document.getElementById('menu-icon');
  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Ouvrir le menu' : 'Fermer le menu');
    if (icon) icon.setAttribute('d', isOpen ? 'M4 6h16M4 12h16M4 18h16' : 'M6 18L18 6M6 6l12 12');
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !menu?.classList.contains('hidden')) {
      menu?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
      if (icon) icon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
      toggle?.focus();
    }
  });
</script>
