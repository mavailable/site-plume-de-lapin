---
import Button from '@/components/ui/Button.astro';
import { getAbout } from '@/data/content';

const about = getAbout();
---

<section id="a-propos" class="py-20 sm:py-28 bg-secondary-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-0">
      <!-- Photo — 60% largeur -->
      <div class="lg:col-span-7">
        <!-- TODO: Remplacer par photo de Sandra et Gaylord -->
        <div class="aspect-[4/3] lg:aspect-[3/2] bg-primary-900 flex items-center justify-center text-primary-600">
          <div class="text-center">
            <svg class="w-20 h-20 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="0.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <p class="mt-3 text-sm text-primary-400">Photo à venir</p>
          </div>
        </div>
      </div>

      <!-- Texte -->
      <article class="lg:col-span-5 bg-white p-8 sm:p-12 flex flex-col justify-center">
        <p class="text-accent-600 text-xs uppercase tracking-[0.2em] font-semibold mb-3">Notre histoire</p>
        <h2 class="text-2xl sm:text-3xl font-heading font-bold text-primary-950 mb-2">
          {about.directorName}
        </h2>
        <p class="text-neutral-500 font-medium mb-6 italic">{about.tagline}</p>

        <div class="text-neutral-700 space-y-4 leading-relaxed text-sm">
          <p>{about.paragraph1}</p>
          <p>{about.paragraph2}</p>
          <p>{about.paragraph3}</p>
        </div>

        <div class="mt-8">
          <Button href="/a-propos" variant="outline">
            Lire la suite &rarr;
          </Button>
        </div>
      </article>
    </div>
  </div>
</section>
