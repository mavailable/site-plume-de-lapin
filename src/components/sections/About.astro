---
import Button from '@/components/ui/Button.astro';
import { getAbout } from '@/data/content';

const about = getAbout();
---

<section id="a-propos" class="py-16 sm:py-24 bg-secondary-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
      <!-- Photos -->
      <div class="relative">
        <div class="aspect-[4/5] bg-secondary-200 rounded-xl flex items-center justify-center shadow-lg">
          <div class="text-center text-secondary-400">
            <svg class="w-16 h-16 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="0.75" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <p class="mt-2 text-sm">Sandra & Gaylord</p>
          </div>
        </div>
        <div class="absolute -bottom-6 -right-4 sm:right-8 w-32 h-32 bg-primary-100 rounded-xl border-4 border-secondary-50 shadow-lg flex items-center justify-center">
          <div class="text-center text-primary-300">
            <svg class="w-8 h-8 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="0.75"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
            <p class="mt-1 text-[10px]">La vie à la ferme</p>
          </div>
        </div>
      </div>

      <!-- Texte -->
      <article class="lg:py-6">
        <span class="inline-block bg-primary-100 text-primary-800 text-xs font-semibold px-4 py-1.5 rounded-full border border-primary-200 mb-5">
          Notre histoire
        </span>
        <h2 class="text-2xl sm:text-3xl font-heading font-bold text-primary-900">
          {about.directorName}
        </h2>
        <p class="text-primary-600 font-medium mt-2 italic mb-6">{about.tagline}</p>

        <div class="text-neutral-700 space-y-4 leading-relaxed">
          <p>{about.paragraph1}</p>
          <p>{about.paragraph2}</p>
        </div>

        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <Button href="/a-propos" variant="primary">
            Lire la suite
          </Button>
          <Button href="/contact" variant="ghost">
            Nous rendre visite
          </Button>
        </div>
      </article>
    </div>
  </div>
</section>
