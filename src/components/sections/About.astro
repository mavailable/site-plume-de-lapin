---
import Button from '@/components/ui/Button.astro';
import { getAbout } from '@/data/content';

const about = getAbout();
---

<section id="a-propos" class="py-16 sm:py-24 bg-secondary-50">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="flex flex-col items-center text-center">
      <!-- Photo ronde -->
      <div class="w-36 h-36 rounded-full bg-primary-200 flex items-center justify-center text-primary-500 shadow-lg border-4 border-white mb-8">
        <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="0.75" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
      </div>

      <h2 class="text-3xl sm:text-4xl font-heading font-bold text-primary-900">
        {about.directorName}
      </h2>
      <p class="text-primary-600 font-medium mt-2 italic">{about.tagline}</p>

      <div class="mt-8 text-neutral-700 space-y-4 leading-relaxed max-w-2xl text-left">
        <p>{about.paragraph1}</p>
        <p>{about.paragraph2}</p>
        <p>{about.paragraph3}</p>
      </div>

      <div class="mt-8">
        <Button href="/a-propos" variant="outline">
          Lire la suite →
        </Button>
      </div>
    </div>
  </div>
</section>
