---
import Button from '@/components/ui/Button.astro';
---

<section class="py-16 sm:py-20 bg-accent-500 relative overflow-hidden">
  <div class="absolute -top-20 -left-20 w-64 h-64 bg-accent-400 rounded-full opacity-50 blur-3xl"></div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
    <h2 class="text-3xl sm:text-4xl font-heading font-bold text-secondary-950">
      Envie de produits frais et locaux ?
    </h2>
    <p class="mt-4 text-secondary-800 max-w-lg mx-auto">
      Composez votre panier en ligne et venez récupérer votre commande à la ferme.
    </p>
    <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
      <Button href="/boutique" variant="primary" size="lg">
        Commander en ligne
      </Button>
      <Button href="/contact" variant="ghost" size="lg" class="text-secondary-900 hover:bg-secondary-900/10">
        Nous contacter
      </Button>
    </div>
  </div>
</section>
