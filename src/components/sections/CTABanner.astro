---
import Button from '@/components/ui/Button.astro';
---

<section class="py-16 sm:py-20 bg-primary-600">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
    <h2 class="text-3xl sm:text-4xl font-heading font-bold text-white">
      Envie de produits frais ?
    </h2>
    <p class="mt-4 text-white/90 max-w-lg mx-auto">
      Composez votre panier en ligne et venez récupérer votre commande à la ferme.
    </p>
    <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
      <Button href="/boutique" variant="secondary" size="lg">
        Commander en ligne
      </Button>
      <Button href="/contact" variant="ghost" size="lg" class="text-white hover:text-white hover:bg-white/10">
        Nous contacter
      </Button>
    </div>
  </div>
</section>
