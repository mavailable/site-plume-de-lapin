---
import { getFaq } from '@/data/content';

const faqItems = getFaq();

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": { "@type": "Answer", "text": item.answer }
  }))
};
---

<section id="faq" class="py-20 sm:py-28 bg-white">
  <div class="max-w-3xl mx-auto px-4 sm:px-6">
    <p class="text-accent-600 text-xs uppercase tracking-[0.2em] font-semibold mb-3">FAQ</p>
    <h2 class="text-3xl sm:text-4xl font-heading font-bold text-primary-950 mb-14">
      Questions fréquentes
    </h2>

    <div class="divide-y divide-neutral-200 border-t border-neutral-200">
      {faqItems.map((item) => (
        <details class="group">
          <summary class="flex items-center justify-between py-6 cursor-pointer text-neutral-900 font-medium hover:text-primary-700 transition-colors min-h-[44px] list-none">
            <span class="pr-4">{item.question}</span>
            <svg class="w-5 h-5 text-neutral-400 group-open:rotate-45 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
          </summary>
          <div class="pb-6 text-neutral-600 leading-relaxed -mt-2">
            {item.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
