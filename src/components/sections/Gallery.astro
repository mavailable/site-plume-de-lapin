---
const photos = [
  { caption: 'La ferme', aspect: 'col-span-2 row-span-2' },
  { caption: 'Les poules', aspect: '' },
  { caption: 'Les œufs', aspect: '' },
  { caption: 'Les lapins', aspect: '' },
  { caption: 'Le poulailler', aspect: '' },
  { caption: 'Sandra & Gaylord', aspect: 'col-span-2' },
];
---

<section id="galerie" class="py-16 sm:py-24 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <span class="inline-block bg-accent-100 text-accent-800 text-xs font-semibold px-4 py-1.5 rounded-full border border-accent-200 mb-4">
        La ferme en images
      </span>
      <h2 class="text-3xl sm:text-4xl font-heading font-bold text-primary-900">
        Bienvenue chez nous
      </h2>
      <p class="mt-3 text-neutral-600">Photos à venir — notre ferme ouvre bientôt ses portes</p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 sm:gap-4">
      {photos.map((photo) => (
        <div class={`${photo.aspect} bg-neutral-100 rounded-xl flex items-center justify-center min-h-[140px] group hover:bg-neutral-200 transition-colors`}>
          <div class="text-center text-neutral-400 group-hover:text-neutral-500 transition-colors">
            <svg class="w-8 h-8 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="0.75" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <p class="mt-1 text-xs">{photo.caption}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
