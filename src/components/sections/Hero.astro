---
import Button from '@/components/ui/Button.astro';
import { getHero } from '@/data/content';

const hero = getHero();
---

<section id="hero" class="bg-secondary-50 py-16 sm:py-24 lg:py-32 relative overflow-hidden">
  <!-- Forme organique décorative -->
  <div class="absolute -top-20 -right-20 w-96 h-96 bg-primary-100 rounded-full opacity-40 blur-3xl"></div>
  <div class="absolute -bottom-32 -left-32 w-[500px] h-[500px] bg-accent-100 rounded-full opacity-30 blur-3xl"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 text-center">
    <!-- Logo grand centré -->
    <div class="w-28 h-28 mx-auto bg-white rounded-full border-2 border-primary-200 flex items-center justify-center shadow-lg mb-8">
      <!-- TODO: Remplacer par le vrai logo SVG -->
      <span class="text-primary-800 text-2xl font-heading font-bold">PL</span>
    </div>

    <span class="inline-block bg-primary-100 text-primary-800 text-xs font-semibold px-4 py-1.5 rounded-full mb-5 border border-primary-200">
      Ferme familiale en Meurthe-et-Moselle
    </span>

    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-primary-900 leading-tight max-w-3xl mx-auto">
      {hero.title}
    </h1>
    <p class="mt-6 text-lg text-neutral-600 leading-relaxed max-w-2xl mx-auto">
      {hero.subtitle}
    </p>
    <div class="mt-9 flex flex-col sm:flex-row gap-4 justify-center">
      <Button href={hero.ctaLink} variant="primary" size="lg">
        {hero.ctaText}
      </Button>
      <Button href={hero.ctaSecondaryLink} variant="outline" size="lg">
        {hero.ctaSecondaryText}
      </Button>
    </div>
    <p class="mt-5 text-sm text-neutral-500">{hero.reassurance}</p>
  </div>

  <!-- Séparateur vague -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full text-white" preserveAspectRatio="none">
      <path d="M0 60h1440V30c-240 20-480 30-720 25S240 30 0 5v55z" fill="currentColor"/>
    </svg>
  </div>
</section>
