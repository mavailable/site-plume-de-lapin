---
import Button from '@/components/ui/Button.astro';
import { getHero } from '@/data/content';

const hero = getHero();
---

<section id="hero" class="bg-gradient-to-b from-primary-50 to-white py-20 sm:py-28 lg:py-36">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
    <span class="inline-block bg-primary-100 text-primary-700 text-sm font-semibold px-4 py-1.5 rounded-full mb-6">
      Ferme familiale — Lantefontaine (54)
    </span>
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-heading font-bold text-primary-900 leading-tight max-w-4xl mx-auto">
      {hero.title}
    </h1>
    <p class="mt-6 text-lg sm:text-xl text-neutral-600 leading-relaxed max-w-2xl mx-auto">
      {hero.subtitle}
    </p>
    <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
      <Button href={hero.ctaLink} variant="primary" size="lg">
        {hero.ctaText}
      </Button>
      <Button href={hero.ctaSecondaryLink} variant="outline" size="lg">
        {hero.ctaSecondaryText}
      </Button>
    </div>
    <p class="mt-5 text-sm text-neutral-500">
      {hero.reassurance}
    </p>
  </div>
</section>
