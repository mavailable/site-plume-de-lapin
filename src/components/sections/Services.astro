---
import Button from '@/components/ui/Button.astro';
import { getServices } from '@/data/content';

const services = getServices();
const badges = ['Œufs', 'Volailles', 'Lapin'];
const bgColors = ['bg-primary-50 border-primary-100', 'bg-accent-50 border-accent-100', 'bg-secondary-50 border-secondary-100'];
const photoCaptions = ['Œufs de nos poules et cailles', 'Nos volailles dans leur poulailler', 'Nos lapins en clapiers'];
---

<section id="produits" class="py-16 sm:py-24 bg-neutral-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center max-w-2xl mx-auto mb-14">
      <span class="inline-block bg-primary-100 text-primary-800 text-xs font-semibold px-4 py-1.5 rounded-full border border-primary-200 mb-4">
        Nos produits
      </span>
      <h2 class="text-3xl sm:text-4xl font-heading font-bold text-primary-900">
        Des produits fermiers, du pré à votre table
      </h2>
      <p class="mt-4 text-neutral-600">
        Nourris aux céréales cultivées sur la ferme, nos animaux grandissent à leur rythme sur notre exploitation familiale.
      </p>
    </div>

    <div class="space-y-8 max-w-4xl mx-auto">
      {services.map((service, i) => (
        <article class={`${bgColors[i % 3]} border rounded-xl overflow-hidden group hover:shadow-md transition-shadow`}>
          <div class={`flex flex-col ${i % 2 === 1 ? 'md:flex-row-reverse' : 'md:flex-row'} gap-0`}>
            <!-- Photo placeholder -->
            <div class="md:w-2/5 aspect-[4/3] md:aspect-auto bg-neutral-200/50 flex items-center justify-center relative">
              <div class="text-center text-neutral-400">
                <svg class="w-14 h-14 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="0.75" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <p class="mt-2 text-xs">{photoCaptions[i]}</p>
              </div>
              <!-- Badge catégorie -->
              <span class="absolute top-4 left-4 bg-white text-primary-700 text-xs font-bold px-3 py-1.5 rounded-full border border-primary-200 shadow-sm">
                {badges[i]}
              </span>
            </div>
            <!-- Contenu -->
            <div class="md:w-3/5 p-6 sm:p-8 flex flex-col justify-center">
              <h3 class="font-heading font-bold text-xl text-neutral-900">{service.title}</h3>
              <p class="mt-3 text-neutral-600 leading-relaxed">{service.description}</p>
              <div class="mt-5">
                <a href="/boutique" class="inline-flex items-center gap-1 text-sm font-semibold text-primary-600 hover:text-primary-700">
                  Voir les produits
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
                </a>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="text-center mt-12">
      <Button href="/boutique" variant="primary" size="lg">
        Découvrir la boutique
      </Button>
    </div>
  </div>
</section>
