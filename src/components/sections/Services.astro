---
import Button from '@/components/ui/Button.astro';
import { getServices } from '@/data/content';

const services = getServices();
const bgColors = ['bg-primary-50', 'bg-accent-50', 'bg-secondary-50'];
const iconColors = ['text-primary-600', 'text-accent-700', 'text-secondary-600'];
---

<section id="produits" class="py-16 sm:py-24 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center max-w-2xl mx-auto mb-14">
      <h2 class="text-3xl sm:text-4xl font-heading font-bold text-primary-900">
        Des produits fermiers, du pré à votre table
      </h2>
      <p class="mt-4 text-neutral-600">
        Élevés en plein air, nos animaux grandissent à leur rythme sur notre exploitation familiale.
      </p>
    </div>

    <div class="flex flex-col md:flex-row gap-8 justify-center items-stretch max-w-4xl mx-auto">
      {services.map((service, i) => (
        <article class="flex-1 text-center group">
          <!-- Image ronde placeholder -->
          <div class={`w-40 h-40 mx-auto rounded-full ${bgColors[i % 3]} flex items-center justify-center mb-6 shadow-md group-hover:shadow-xl transition-shadow`}>
            <svg class={`w-16 h-16 ${iconColors[i % 3]}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-xl text-neutral-900">{service.title}</h3>
          <p class="mt-3 text-neutral-600 text-sm leading-relaxed max-w-xs mx-auto">{service.shortDesc}</p>
          <a href="/boutique" class="mt-4 inline-block text-sm font-semibold text-primary-600 hover:text-primary-700">
            Voir les produits →
          </a>
        </article>
      ))}
    </div>

    <div class="text-center mt-14">
      <Button href="/boutique" variant="primary" size="lg">
        Découvrir la boutique
      </Button>
    </div>
  </div>
</section>
