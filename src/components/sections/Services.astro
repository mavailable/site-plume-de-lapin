---
import Button from '@/components/ui/Button.astro';
import { getServices } from '@/data/content';

const services = getServices();
const badges = ['Œufs', 'Volailles', 'Lapin'];
const bgColors = ['bg-primary-50 border-primary-100', 'bg-accent-50 border-accent-100', 'bg-secondary-50 border-secondary-100'];
---

<section id="produits" class="py-16 sm:py-24 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <h2 class="text-3xl sm:text-4xl font-heading font-bold text-primary-900 text-center">
      Des produits fermiers, du pré à votre table
    </h2>
    <p class="mt-4 text-neutral-600 text-center max-w-2xl mx-auto">
      Nourris aux céréales cultivées sur la ferme, nos animaux grandissent à leur rythme sur notre exploitation familiale.
    </p>

    <div class="mt-14 space-y-6 max-w-3xl mx-auto">
      {services.map((service, i) => (
        <article class={`${bgColors[i % 3]} border rounded-xl p-6 sm:p-8 flex flex-col sm:flex-row gap-6 items-start group hover:shadow-md transition-shadow`}>
          <!-- Badge coin -->
          <div class="flex-shrink-0">
            <span class="inline-block bg-white text-primary-700 text-xs font-bold px-3 py-1.5 rounded-full border border-primary-200 shadow-sm">
              {badges[i]}
            </span>
          </div>
          <div class="flex-1">
            <h3 class="font-heading font-bold text-lg text-neutral-900">{service.title}</h3>
            <p class="mt-2 text-neutral-600 text-sm leading-relaxed">{service.description}</p>
            <a href="/boutique" class="mt-3 inline-block text-sm font-semibold text-primary-600 hover:text-primary-700">
              Voir les produits →
            </a>
          </div>
        </article>
      ))}
    </div>

    <div class="text-center mt-12">
      <Button href="/boutique" variant="primary" size="lg">
        Découvrir la boutique
      </Button>
    </div>
  </div>
</section>
