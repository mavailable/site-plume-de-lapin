---
import Button from '@/components/ui/Button.astro';
import { getServices } from '@/data/content';

const services = getServices();
---

<section id="produits" class="py-20 sm:py-28 bg-neutral-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <p class="text-accent-600 text-xs uppercase tracking-[0.2em] font-semibold mb-3">Nos produits</p>
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-primary-950 max-w-xl">
      Du pré à votre table
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-0 mt-14 border border-neutral-200">
      {services.map((service, i) => (
        <article class={`p-8 sm:p-10 ${i < 2 ? 'md:border-r border-neutral-200' : ''} ${i > 0 ? 'border-t md:border-t-0 border-neutral-200' : ''} group hover:bg-primary-950 transition-colors duration-300`}>
          <span class="text-6xl font-heading font-bold text-neutral-200 group-hover:text-primary-800 transition-colors">
            0{i + 1}
          </span>
          <h3 class="mt-4 font-heading font-bold text-xl text-neutral-900 group-hover:text-white transition-colors">
            {service.title}
          </h3>
          <p class="mt-3 text-neutral-600 text-sm leading-relaxed group-hover:text-white/80 transition-colors">
            {service.description}
          </p>
          <a href="/boutique" class="mt-6 inline-block text-sm font-semibold text-primary-700 group-hover:text-accent-400 uppercase tracking-wider transition-colors">
            Voir les produits &rarr;
          </a>
        </article>
      ))}
    </div>

    <div class="mt-12">
      <Button href="/boutique" variant="primary" size="lg">
        Découvrir la boutique
      </Button>
    </div>
  </div>
</section>
