---
const stats = [
  { value: '3', label: 'Catégories de produits', icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4' },
  { value: '100%', label: 'Céréales de la ferme', icon: 'M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z' },
  { value: '0 km', label: 'Sans intermédiaire', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
  { value: '2025', label: 'Création', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z' },
];
---

<section class="py-14 bg-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {stats.map((stat) => (
        <div class="text-center">
          <div class="w-12 h-12 mx-auto rounded-lg bg-primary-100 flex items-center justify-center mb-3">
            <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d={stat.icon} />
            </svg>
          </div>
          <p class="text-3xl font-heading font-bold text-primary-800">{stat.value}</p>
          <p class="mt-1 text-sm text-neutral-500">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
