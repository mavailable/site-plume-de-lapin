---
const stats = [
  { value: '3', label: 'Catégories de produits' },
  { value: '100%', label: 'Plein air' },
  { value: '0', label: 'Intermédiaire' },
  { value: '2025', label: 'Création' },
];
---

<section class="bg-neutral-950 py-10 border-y border-neutral-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-neutral-800">
      {stats.map((stat) => (
        <div class="text-center py-4 px-6">
          <p class="text-4xl sm:text-5xl font-heading font-bold text-accent-500">{stat.value}</p>
          <p class="mt-2 text-xs uppercase tracking-[0.15em] text-neutral-400">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
