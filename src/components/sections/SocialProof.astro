---
const stats = [
  { value: '3', label: 'Catégories de produits', icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4' },
  { value: '100%', label: 'Céréales de la ferme', icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064' },
  { value: '0', label: 'Intermédiaire', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
  { value: '2017', label: 'Début de l\'aventure', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z' },
];
---

<section class="py-14 bg-neutral-50">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {stats.map((stat) => (
        <div class="text-center bg-white rounded-xl p-6 border border-neutral-200 shadow-sm">
          <div class="w-11 h-11 mx-auto rounded-lg bg-primary-100 flex items-center justify-center mb-3">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d={stat.icon} />
            </svg>
          </div>
          <p class="text-3xl font-heading font-bold text-primary-800">{stat.value}</p>
          <p class="mt-1 text-sm text-neutral-500">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
