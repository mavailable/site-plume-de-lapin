---
const stats = [
  { value: '3', label: 'Catégories de produits', icon: '🥚' },
  { value: '100%', label: 'Plein air', icon: '☀️' },
  { value: '0 km', label: 'Sans intermédiaire', icon: '🤝' },
  { value: '2025', label: 'Création', icon: '🌱' },
];
---

<section class="py-12 bg-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {stats.map((stat) => (
        <div class="text-center bg-primary-50 rounded-2xl py-6 px-4">
          <p class="text-3xl sm:text-4xl font-heading font-bold text-primary-700">{stat.value}</p>
          <p class="mt-2 text-sm text-neutral-600">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
