---
import { getTestimonials } from '@/data/content';

const testimonials = getTestimonials();
---

<section id="temoignages" class="py-16 sm:py-24 bg-primary-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <h2 class="text-3xl sm:text-4xl font-heading font-bold text-primary-900 text-center mb-4">
      Ce que disent nos clients
    </h2>
    <p class="text-center text-neutral-500 text-sm mb-14">Exemples illustratifs — vrais témoignages à venir</p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {testimonials.map((t) => (
        <article class="bg-white rounded-2xl p-7 shadow-sm hover:shadow-md transition-shadow">
          <div class="flex gap-1 mb-4">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4 text-accent-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            ))}
          </div>
          <blockquote class="text-neutral-700 text-sm leading-relaxed">
            "{t.quote}"
          </blockquote>
          <footer class="mt-5 flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-primary-100 flex items-center justify-center text-primary-600 text-xs font-bold">
              {t.name.charAt(0)}
            </div>
            <div>
              <p class="font-semibold text-neutral-900 text-sm">{t.name}</p>
              <p class="text-xs text-neutral-500">{t.context}</p>
            </div>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>
