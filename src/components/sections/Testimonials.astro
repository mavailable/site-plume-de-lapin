---
import { getTestimonials } from '@/data/content';

const testimonials = getTestimonials();
---

<section id="temoignages" class="py-20 sm:py-28 bg-neutral-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <p class="text-accent-600 text-xs uppercase tracking-[0.2em] font-semibold mb-3">Témoignages</p>
    <h2 class="text-3xl sm:text-4xl font-heading font-bold text-primary-950 mb-4">
      Ce que disent nos clients
    </h2>
    <p class="text-neutral-500 text-sm mb-14">Exemples illustratifs — vrais témoignages à venir</p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-0 border border-neutral-200">
      {testimonials.map((t, i) => (
        <article class={`p-8 ${i < 2 ? 'md:border-r border-neutral-200' : ''} ${i > 0 ? 'border-t md:border-t-0 border-neutral-200' : ''}`}>
          <div class="text-accent-500 text-5xl font-heading font-bold leading-none mb-4">"</div>
          <blockquote class="text-neutral-700 leading-relaxed">
            {t.quote}
          </blockquote>
          <footer class="mt-6 pt-4 border-t border-neutral-200">
            <p class="font-heading font-bold text-neutral-900">{t.name}</p>
            <p class="text-xs uppercase tracking-wider text-neutral-500 mt-1">{t.context}</p>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>
