---
import { getTestimonials } from '@/data/content';

const testimonials = getTestimonials();
---

<section id="temoignages" class="py-16 sm:py-24 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <h2 class="text-3xl sm:text-4xl font-heading font-bold text-primary-900 text-center mb-4">
      Ce que disent nos clients
    </h2>
    <p class="text-center text-neutral-500 text-sm mb-14">Exemples illustratifs — vrais témoignages à venir</p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {testimonials.map((t) => (
        <article class="bg-secondary-50 rounded-xl p-6 border border-secondary-100">
          <blockquote class="text-neutral-700 leading-relaxed italic">
            « {t.quote} »
          </blockquote>
          <footer class="mt-5 flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-primary-200 flex items-center justify-center text-primary-700 text-xs font-bold">
              {t.name.charAt(0)}
            </div>
            <div>
              <p class="font-heading font-bold text-neutral-900 text-sm">{t.name}</p>
              <p class="text-xs text-neutral-500">{t.context}</p>
            </div>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>
