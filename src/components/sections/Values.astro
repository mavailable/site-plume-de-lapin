---
const values = [
  { title: 'Bien-être animal', description: 'Plein air, espace, alimentation saine. Pas de cages.', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z' },
  { title: 'Circuit court', description: 'Du producteur au consommateur, sans intermédiaire.', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
  { title: 'Terroir lorrain', description: 'Lantefontaine, pays de Briey. Fournisseurs locaux.', icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z' },
  { title: 'Ferme familiale', description: 'Sandra et Gaylord, une ferme à taille humaine.', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
];
---

<section id="valeurs" class="py-16 sm:py-24 bg-primary-800 relative overflow-hidden">
  <!-- Motif organique -->
  <div class="absolute top-0 right-0 w-72 h-72 bg-primary-700 rounded-full opacity-50 blur-3xl -translate-y-1/2 translate-x-1/3"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
    <h2 class="text-3xl sm:text-4xl font-heading font-bold text-white text-center mb-14">
      Ce en quoi nous croyons
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-3xl mx-auto">
      {values.map((value) => (
        <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/10">
          <div class="w-11 h-11 rounded-lg bg-accent-500 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-secondary-900" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d={value.icon} />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-white">{value.title}</h3>
          <p class="mt-2 text-sm text-white/80 leading-relaxed">{value.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
