---
const values = [
  { title: 'Bien-être animal', description: 'Plein air, espace, alimentation saine. Pas de cages.', color: 'bg-primary-100 text-primary-700' },
  { title: 'Circuit court', description: 'Du producteur au consommateur, sans intermédiaire.', color: 'bg-accent-100 text-accent-800' },
  { title: 'Terroir lorrain', description: 'Lantefontaine, pays de Briey. Fournisseurs locaux.', color: 'bg-secondary-100 text-secondary-700' },
  { title: 'Ferme familiale', description: 'Sandra et Gaylord, une ferme à taille humaine.', color: 'bg-primary-100 text-primary-700' },
];
---

<section id="valeurs" class="py-16 sm:py-24 bg-neutral-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <h2 class="text-3xl sm:text-4xl font-heading font-bold text-primary-900 text-center mb-14">
      Ce en quoi nous croyons
    </h2>

    <div class="flex flex-wrap justify-center gap-4 max-w-3xl mx-auto">
      {values.map((value) => (
        <div class={`${value.color} rounded-2xl px-6 py-4 flex-1 min-w-[200px] max-w-[280px]`}>
          <h3 class="font-heading font-bold">{value.title}</h3>
          <p class="mt-1 text-sm opacity-80">{value.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
