---
interface Props {
  variant?: 'available' | 'unavailable' | 'info';
  class?: string;
}

const { variant = 'info', class: className = '' } = Astro.props;

const variantClasses = {
  available: 'bg-primary-100 text-primary-700',
  unavailable: 'bg-neutral-100 text-neutral-500',
  info: 'bg-accent-100 text-accent-800',
};
---

<span class={`inline-block text-xs font-semibold px-3 py-1 rounded-full ${variantClasses[variant]} ${className}`}>
  <slot />
</span>
