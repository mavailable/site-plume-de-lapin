---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import { social } from '@/data/business';
---

<BaseLayout
  title="Merci — Plume de Lapin"
  description="Votre message a bien été envoyé. Nous vous répondrons rapidement."
>
  <meta name="robots" content="noindex" slot="head" />
  <Header slot="header" />

  <section class="py-20 text-center max-w-2xl mx-auto px-6">
    <div class="w-16 h-16 mx-auto bg-primary-100 rounded-full flex items-center justify-center mb-6">
      <svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
    </div>
    <h1 class="text-3xl font-heading font-bold text-primary-900">Merci !</h1>
    <p class="mt-4 text-neutral-600 text-lg">
      Nous avons bien reçu votre demande et nous vous répondrons dans les plus brefs délais.
      En attendant, suivez notre quotidien à la ferme sur Facebook.
    </p>
    <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={social.facebook}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-accent-500 text-secondary-900 font-semibold py-3 px-6 rounded hover:bg-accent-600 transition-colors min-h-[44px]"
      >
        Suivre sur Facebook
      </a>
      <a
        href="/boutique"
        class="inline-block border-2 border-primary-600 text-primary-700 font-semibold py-3 px-6 rounded hover:bg-primary-50 transition-colors min-h-[44px]"
      >
        Retour à la boutique
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
